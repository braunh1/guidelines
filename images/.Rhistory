TRUE ~ NA_real_  # Use NA_real_ for numeric NA
),
BY_numeric = case_when(
hue == 'B' ~ 1,
hue == 'Y' ~ -1,
hue %in% c('R', 'G') ~ 0,
TRUE ~ NA_real_  # Use NA_real_ for numeric NA
)
)
